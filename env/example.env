# riscv-uarch-bench environment configuration
# Copy this file to create a new environment: cp env/example.env env/mybox.env
# Activate with: UARCH_ENV=mybox make
#
# Format: pure KEY=VALUE — no export, no conditionals, no shell expansion
# This file is sourced by both shell scripts and Makefile

# RISC-V toolchain root path
# Must contain bin/riscv64-unknown-linux-gnu-gcc and bin/riscv64-unknown-elf-gcc
RISCV_TOOLCHAIN=/opt/riscv

# ISA march string (unified for all targets)
# Must include _zicntr for rdcycle/rdinstret access on spike
MARCH=rv64gcv_zba_zbb_zbs

# Architecture profile (selects arch/<ARCH>.h)
ARCH=default
