# riscv-uarch-bench environment configuration
# Format: pure KEY=VALUE (shell source + Makefile include compatible)

# RISC-V toolchain root path (linux-gnu)
RISCV_TOOLCHAIN=/work/stu/yzhang/workspace/riscv

# RISC-V bare-metal toolchain root path (elf, for pk build)
# Set same as RISCV_TOOLCHAIN if both targets are in one installation
RISCV_ELF_TOOLCHAIN=/work/stu/yzhang/workspace/riscv

# ISA march string (unified for all targets: spike/linux/checkpoint)
MARCH=rv64gcv_zba_zbb_zbs_zfh_zfhmin_zfa_zicond_zcb_zicboz_zicbom_zicbop_zicntr_zicsr_zifencei_zimop_zkt_zvbb_zvfhmin_zvkt_zihintpause_zihintntl

# Architecture profile (selects arch/<ARCH>.h)
ARCH=default
