#!/usr/bin/env bash
# Description: 打包项目用于部署到目标机器
source "$(dirname "$0")/lib/common.sh"

show_help() {
    cat <<'EOF'
用法:
  uarch pack [选项]          创建部署压缩包
  uarch pack --help          显示帮助

选项:
  --mode <src|spike|cli>  打包模式 (默认: src)
                          src   — 打包源码，目标机 make 后运行
                          spike — 打包 bin_spike 预编译产物，直接跑
                          cli   — 仅打包 uarch 命令及相关脚本
  --output|-o <file>      输出文件名 (默认: 自动生成带时间戳的名称)

两种模式都会打包:
  scripts/    uarch CLI 及子命令
  uarch       CLI 入口符号链接
  data/       参考值 JSON (供 uarch check 使用)
  arch/       微架构 profile

src 模式额外打包:
  src/        测试源码
  Makefile    构建脚本

spike 模式额外打包:
  bin_spike/  spike 预编译二进制

示例:
  uarch pack                        # 默认打包源码
  uarch pack --mode spike           # 打包 spike 预编译产物
  uarch pack --mode src -o out.tar.gz
EOF
    exit 0
}

MODE="src"
OUTNAME=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) show_help ;;
        --mode)
            MODE="${2:?'--mode 需要参数: src 或 spike'}"
            [[ "$MODE" == "src" || "$MODE" == "spike" || "$MODE" == "cli" ]] || die "无效模式: $MODE (可选: src, spike, cli)"
            shift 2 ;;
        --output|-o) OUTNAME="${2:?'--output 需要文件名'}"; shift 2 ;;
        *) die "未知参数: $1" ;;
    esac
done

[[ -z "$OUTNAME" ]] && OUTNAME="riscv_uarch_bench_${MODE}_$(date +%Y%m%d_%H%M%S).tar.gz"

cd "$PROJECT_DIR"

# 公共文件（两种模式都包含）
COMMON_FILES=(
    scripts/
    uarch
    data/
    arch/
)

# 检查公共文件是否存在
for f in "${COMMON_FILES[@]}"; do
    [[ -e "$f" ]] || warn "缺失: $f (跳过)"
done

if [[ "$MODE" == "src" ]]; then
    [[ -d "src" ]] || die "src/ 目录不存在"
    echo "模式: src (源码打包，目标机需 make)"

    tar czf "$OUTNAME" \
        --exclude='_gen_workspace' \
        --exclude='.claude' \
        --exclude='.humanize' \
        --exclude='.gitignore' \
        --exclude='*.o' \
        --exclude='logs' \
        "${COMMON_FILES[@]}" \
        src/ \
        Makefile

elif [[ "$MODE" == "spike" ]]; then
    [[ -d "bin_spike" ]] || die "bin_spike/ 目录不存在，请先 make spike"
    echo "模式: spike (预编译打包，目标机直接运行)"

    tar czf "$OUTNAME" \
        --exclude='.claude' \
        --exclude='.humanize' \
        --exclude='logs' \
        "${COMMON_FILES[@]}" \
        bin_spike/

elif [[ "$MODE" == "cli" ]]; then
    echo "模式: cli (仅打包 uarch 命令相关)"

    tar czf "$OUTNAME" \
        "${COMMON_FILES[@]}"
fi

ok "已打包: $OUTNAME ($(du -h "$OUTNAME" | cut -f1))"
echo ""
echo "包含内容:"
echo "  scripts/         uarch CLI 及子命令"
echo "  data/            参考值 (reference.json)"
echo "  arch/            微架构 profile"
if [[ "$MODE" == "src" ]]; then
    echo "  src/             测试源码"
    echo "  Makefile         构建脚本"
    echo ""
    echo "部署: scp $OUTNAME target: && ssh target 'tar xzf $OUTNAME && make'"
elif [[ "$MODE" == "spike" ]]; then
    echo "  bin_spike/       spike 预编译二进制"
    echo ""
    echo "部署: scp $OUTNAME target: && ssh target 'tar xzf $OUTNAME && ./uarch run'"
elif [[ "$MODE" == "cli" ]]; then
    echo ""
    echo "部署: scp $OUTNAME target: && ssh target 'tar xzf $OUTNAME'"
fi
