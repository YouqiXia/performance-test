#!/usr/bin/env bash
# Description: 打包项目用于部署到目标机器
source "$(dirname "$0")/lib/common.sh"

show_help() {
    cat <<'EOF'
用法:
  uarch pack [目录/文件...] [选项]    创建部署压缩包
  uarch pack --help                   显示帮助

位置参数:
  可指定任意目录或文件，会与默认基础包合并打包。

选项:
  --mode <src|spike|cli>  快捷模式（预设常用组合）
                          src   — 默认包 + src/ + Makefile + env/
                          spike — 默认包 + bin/spike/
                          cli   — 仅默认基础包
  --output|-o <file>      输出文件名 (默认: 自动生成带时间戳的名称)

默认基础包（每次都会打包）:
  scripts/    uarch CLI 及子命令
  uarch       CLI 入口符号链接
  data/       参考值 JSON (供 uarch check 使用)
  arch/       微架构 profile
  env/        工具链与环境配置

示例:
  uarch pack                          # 仅打默认基础包
  uarch pack src/ Makefile            # 默认包 + 源码
  uarch pack bin/spike/               # 默认包 + spike 预编译产物
  uarch pack bin/ logs/               # 默认包 + 自定义目录
  uarch pack --mode src               # 等价于 uarch pack src/ Makefile
  uarch pack --mode spike             # 等价于 uarch pack bin/spike/
  uarch pack --mode src bin/          # mode 预设 + 额外目录
  uarch pack -o out.tar.gz src/       # 指定输出文件名
EOF
    exit 0
}

OUTNAME=""
EXTRA_FILES=()
MODE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) show_help ;;
        --mode)
            MODE="${2:?'--mode 需要参数: src, spike 或 cli'}"
            [[ "$MODE" == "src" || "$MODE" == "spike" || "$MODE" == "cli" ]] || die "无效模式: $MODE (可选: src, spike, cli)"
            shift 2 ;;
        --output|-o) OUTNAME="${2:?'--output 需要文件名'}"; shift 2 ;;
        -*) die "未知选项: $1" ;;
        *) EXTRA_FILES+=("$1"); shift ;;
    esac
done

cd "$PROJECT_DIR"

# ── 默认基础包（每次都包含）──────────────────────────────────────
BASE_FILES=(
    scripts/
    uarch
    data/
    arch/
    env/
)

# ── mode 快捷预设 ────────────────────────────────────────────────
case "$MODE" in
    src)   EXTRA_FILES+=(src/ Makefile env/) ;;
    spike) EXTRA_FILES+=(bin/spike/) ;;
    cli)   ;; # 仅基础包
esac

# ── 去重 ─────────────────────────────────────────────────────────
declare -A _seen
UNIQUE_EXTRAS=()
for f in "${EXTRA_FILES[@]}"; do
    # 去掉尾部斜杠用于去重
    key="${f%/}"
    if [[ -z "${_seen[$key]+x}" ]]; then
        _seen[$key]=1
        UNIQUE_EXTRAS+=("$f")
    fi
done

# ── 检查文件/目录是否存在 ────────────────────────────────────────
for f in "${BASE_FILES[@]}"; do
    [[ -e "$f" ]] || warn "基础包缺失: $f (跳过)"
done
for f in "${UNIQUE_EXTRAS[@]}"; do
    [[ -e "$f" ]] || die "指定的路径不存在: $f"
done

# ── 生成输出文件名 ───────────────────────────────────────────────
if [[ -z "$OUTNAME" ]]; then
    if [[ -n "$MODE" ]]; then
        OUTNAME="riscv_uarch_bench_${MODE}_$(date +%Y%m%d_%H%M%S).tar.gz"
    elif [[ ${#UNIQUE_EXTRAS[@]} -eq 0 ]]; then
        OUTNAME="riscv_uarch_bench_base_$(date +%Y%m%d_%H%M%S).tar.gz"
    else
        OUTNAME="riscv_uarch_bench_custom_$(date +%Y%m%d_%H%M%S).tar.gz"
    fi
fi

# ── 合并打包列表 ────────────────────────────────────────────────
ALL_FILES=("${BASE_FILES[@]}" "${UNIQUE_EXTRAS[@]}")

echo "打包内容:"
for f in "${ALL_FILES[@]}"; do
    echo "  $f"
done
echo ""

# ── 打包 ────────────────────────────────────────────────────────
tar czf "$OUTNAME" \
    --exclude='_gen_workspace' \
    --exclude='.claude' \
    --exclude='.humanize' \
    --exclude='.gitignore' \
    --exclude='*.o' \
    --exclude='logs' \
    "${ALL_FILES[@]}"

ok "已打包: $OUTNAME ($(du -h "$OUTNAME" | cut -f1))"
