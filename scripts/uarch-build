#!/usr/bin/env bash
# Description: Build benchmarks and third-party tools
# Second-level dispatcher: uarch build <scope> [args...]
set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

scope="${1:-help}"
shift || true

subcmd="$SCRIPTS_DIR/uarch-build-${scope}"

if [[ -x "$subcmd" ]]; then
    exec "$subcmd" "$@"
elif [[ "$scope" == "help" || "$scope" == "-h" || "$scope" == "--help" ]]; then
    echo "Usage: uarch build <scope> [args]"
    echo ""
    echo "Scopes:"
    for f in "$SCRIPTS_DIR"/uarch-build-*; do
        [[ -x "$f" ]] || continue
        name="$(basename "$f" | sed 's/^uarch-build-//')"
        desc="$(grep '^# Description:' "$f" 2>/dev/null | head -1 | sed 's/^# Description: *//')"
        printf "  %-12s %s\n" "$name" "${desc:-(no description)}"
    done
    echo ""
    echo "Run 'uarch build <scope> --help' for details."
else
    echo "Unknown build scope: $scope" >&2
    exec "$0" help
fi
