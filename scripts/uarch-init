#!/usr/bin/env bash
# Description: Generate default config JSON
source "$(dirname "$0")/lib/common.sh"

show_help() {
    cat <<'EOF'
Usage:
  uarch init <preset> [output.json]    Generate config from preset
  uarch init --help                    Show this help

Presets:
  spike        Spike ISA simulator config
  linux        Real hardware config (taskset pinned)
  checkpoint   Spike checkpoint restore config
  custom       Empty command template

Template variables in command field:
  {spike}       → resolved from install/riscv-isa-sim/bin/spike
  {pk}          → resolved from install/pk/pk
  {march}       → resolved from env MARCH
  {elf}         → replaced per-test at execution time
  {checkpoint}  → derived from elf path at execution time

If output file is omitted, prints to stdout.
EOF
    exit 0
}

[[ $# -lt 1 || "$1" == "--help" || "$1" == "-h" ]] && show_help

PRESET="$1"
OUTFILE="${2:-}"

case "$PRESET" in
    spike)
        JSON='{
    "command": "{spike} --isa={march} {pk} {elf}",
    "bindir":  "bin/spike",
    "jobs":    4,
    "timeout": 1,
    "include": [],
    "exclude": ["cbo_zero"],
    "logdir":  "logs/spike",
    "output":  "logs/spike_summary.txt"
}'
        ;;
    linux)
        JSON='{
    "command": "taskset -c 0 {elf}",
    "bindir":  "bin/linux",
    "jobs":    1,
    "timeout": 1,
    "include": [],
    "exclude": [],
    "logdir":  "logs/linux",
    "output":  "logs/linux_summary.txt"
}'
        ;;
    checkpoint)
        JSON='{
    "command": "{spike} --isa={march} --restore={checkpoint} {pk} {elf}",
    "bindir":  "bin/checkpoint",
    "jobs":    4,
    "timeout": 1,
    "include": [],
    "exclude": [],
    "logdir":  "logs/checkpoint",
    "output":  "logs/checkpoint_summary.txt"
}'
        ;;
    custom)
        JSON='{
    "command": "{elf}",
    "bindir":  "bin/linux",
    "jobs":    1,
    "timeout": 1,
    "include": [],
    "exclude": [],
    "logdir":  "logs/custom",
    "output":  "logs/custom_summary.txt"
}'
        ;;
    *)
        die "Unknown preset '$PRESET'. Use 'spike', 'linux', 'checkpoint', or 'custom'."
        ;;
esac

if [[ -n "$OUTFILE" ]]; then
    echo "$JSON" > "$OUTFILE"
    ok "Config written to $OUTFILE"
else
    echo "$JSON"
fi
